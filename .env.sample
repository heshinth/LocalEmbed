# Hugging Face API Token. Optional - only required if downloading
# multiple models to avoid rate limiting issues
HF_TOKEN=

# The embedding model to load at server startup
# (Default: BAAI/bge-small-en-v1.5)
DEFAULT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

#Number of threads to use for embedding generation. 
#Adjust based on your CPU capabilities.
EMBEDDING_THREADS=8

# Batch size for embedding generation. 
#Adjust based on your system's memory and performance.
BATCH_SIZE=256
